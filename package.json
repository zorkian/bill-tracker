{
  "name": "tracker",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "wrangler dev --local",
    "test": "vitest run",
    "deploy": "wrangler deploy",
    "db:schema": "wrangler d1 execute sm-bill-tracker --local --file=src/db/schema.sql",
    "db:seed": "wrangler d1 execute sm-bill-tracker --local --file=src/db/seed.sql",
    "db:backup": "mkdir -p backups && wrangler d1 export sm-bill-tracker --remote --output=backups/backup-$(date +%Y%m%d-%H%M%S).sql"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.7"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.21",
    "@cloudflare/workers-types": "^4.20260313.1",
    "@types/bcryptjs": "^3.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.72.0"
  }
}
